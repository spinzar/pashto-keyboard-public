{
  "name": "pashto-keyboard",
  "version": "1.0.0",
  "description": "Offline Pashto Keyboard for Linux",
  "main": "src/main.js",
  "author": "iPashto AI <ipashto-ai@example.com>",
  "homepage": "https://github.com/ipashto-ai/pashto-keyboard#readme",
  "license": "Apache-2.0",
  "scripts": {
    "start": "electron .",
    "dist:deb": "electron-builder --linux deb",
    "dist:appimage": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ipashto.pashtokeyboard",
    "productName": "PashtoKeyboard",
    "directories": {
      "buildResources": "assets"
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Utility",
      "maintainer": "iPashto AI <ipashto-ai@example.com>",
      "icon": "assets/icons"
    },
    "deb": {
      "maintainer": "iPashto AI <ipashto-ai@example.com>",
      "compression": "xz"
    }
  }
}
